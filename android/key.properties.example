# Example key.properties file
# Do NOT commit your real key.properties to version control!

# NEW Pro-Level Setup:
# 1. Add KEYSTORE_BASE64 to GitHub Secrets (your .jks converted to base64)
# 2. Add KEY_PROPERTIES to GitHub Secrets with the block below as the value:

# --- SECRET BLOCK START ---
storePassword=YOUR_PASSWORD
keyPassword=YOUR_PASSWORD
keyAlias=upload
storeFile=upload-keystore.jks
# --- SECRET BLOCK END ---

# For local development, create a real 'key.properties' in this folder 
# using the values above.
